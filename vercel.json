{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/react-scripts"
    }
  ],
  "routes": [
    {
      "src": "/api/login",
      "dest": "/api/login.js"
    },
    {
      "src": "/api/register",
      "dest": "/api/register.js"
    },
    {
      "src": "/api/vote",
      "dest": "/api/vote.js"
    },
    {
      "src": "/api/results",
      "dest": "/api/results.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}